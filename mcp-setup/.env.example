# MCP Environment Variables Example
# Copy this file to .env and fill in your actual tokens

# =============================================================================
# Notion Integration
# =============================================================================
# Get your integration token from: https://www.notion.so/my-integrations
# 1. Create a new integration
# 2. Copy the "Internal Integration Secret"
# 3. Share your database with the integration
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# =============================================================================
# Figma Integration
# =============================================================================
# Get your access token from: https://www.figma.com/settings
# 1. Scroll to "Personal Access Tokens"
# 2. Click "Create new token"
# 3. Copy the token
# Get file key from Figma file URL: https://figma.com/file/{FILE_KEY}/...
FIGMA_ACCESS_TOKEN=your_figma_access_token_here
FIGMA_FILE_KEY=your_figma_file_key_here

# =============================================================================
# GitHub Integration
# =============================================================================
# Get your personal access token from: https://github.com/settings/tokens
# 1. Click "Generate new token" → "Generate new token (classic)"
# 2. Select scopes: repo, workflow, read:org
# 3. Copy the token
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPOSITORY=owner/repo

# =============================================================================
# Slack Integration
# =============================================================================
# Get your bot token from: https://api.slack.com/apps
# 1. Create a new Slack app
# 2. Add bot permissions: chat:write, channels:read, channels:history
# 3. Install app to workspace
# 4. Copy "Bot User OAuth Token"
# Get channel ID from Slack URL or API
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=C1234567890

# =============================================================================
# Database Connections
# =============================================================================

# PostgreSQL
# Format: postgresql://user:password@host:port/database
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# MongoDB
# Format: mongodb://host:port/database
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/dbname

# Redis
# Format: redis://host:port
REDIS_URL=redis://localhost:6379

# =============================================================================
# Custom MCP Servers
# =============================================================================

# Morpheus MCP - Knowledge graph queries
MORPHEUS_ENDPOINT=http://localhost:3000

# Data Proxy MCP - Secure data access
DATA_PROXY_ENDPOINT=http://localhost:3001

# =============================================================================
# Security Notes
# =============================================================================
# 1. NEVER commit this file to version control
# 2. Add .env to .gitignore
# 3. Set file permissions to 600 (owner read/write only)
# 4. Rotate tokens regularly (GitHub: every 90 days, others: if compromised)
# 5. Use environment-specific tokens (dev/staging/prod)
# =============================================================================
