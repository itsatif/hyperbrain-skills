# MCP Setup - Git Ignore
# Security: Never commit access tokens or credentials

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Credentials
*.pem
*.key
credentials.json
auth.json
token.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Backup files
*.backup
*.bak
*~

# Test files
test-env.txt
test-tokens.txt
